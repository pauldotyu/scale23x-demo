apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: argocd-tls
  namespace: argocd
spec:
  secretName: argocd-tls
  privateKey:
    rotationPolicy: Always
  commonName: argocd.${COMMON_NAME}
  dnsNames:
    - argocd.${COMMON_NAME}
  usages:
    - digital signature
    - key encipherment
    - server auth
  issuerRef:
    name: letsencrypt-production
    kind: ClusterIssuer